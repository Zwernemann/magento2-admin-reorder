<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Eigene Log-Datei: var/log/fix_edit_order.log -->
    <virtualType name="Zwernemann\FixEditOrder\Logger\Handler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/fix_edit_order.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Zwernemann\FixEditOrder\Logger\Logger"
                 type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">FixEditOrder</argument>
            <argument name="handlers" xsi:type="array">
                <item name="fixeditorder" xsi:type="object">Zwernemann\FixEditOrder\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Zwernemann\FixEditOrder\Plugin\AdminOrder\CancelBeforeCreate">
        <arguments>
            <argument name="logger" xsi:type="object">Zwernemann\FixEditOrder\Logger\Logger</argument>
        </arguments>
    </type>

    <!-- P1/P2: Stock-Validierung und Session-Quote beim Order-Edit -->
    <type name="Magento\Sales\Model\AdminOrder\Create">
        <plugin name="zwernemann_fixeditorder_cancel_before_create"
                type="Zwernemann\FixEditOrder\Plugin\AdminOrder\CancelBeforeCreate"
                sortOrder="10"/>
    </type>

    <!-- P3: Falsche "out of stock"-Fehler im Items-Grid unterdrücken -->
    <type name="Magento\Sales\Block\Adminhtml\Order\Create\Items\Grid">
        <plugin name="zwernemann_fixeditorder_grid_stock_display"
                type="Zwernemann\FixEditOrder\Plugin\Block\Order\Create\Items\GridPlugin"
                sortOrder="10"/>
    </type>

</config>
